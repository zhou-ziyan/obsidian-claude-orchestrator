{
	"name": "obsidian-claude-orchestrator",
	"version": "1.1.6",
	"description": "Orchestrate multiple Claude Code sessions from inside Obsidian via per-project tmux sessions.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"release": "node scripts/auto-bump.mjs && npm run build",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"test": "node --experimental-strip-types tests/utils.test.ts",
		"test:coverage": "c8 --include=src/utils.ts --reporter=text node --experimental-strip-types tests/utils.test.ts",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
		"check": "npm run lint && npm run typecheck && npm run test:coverage",
		"postinstall": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true"
	},
	"author": "Ziyan Zhou <mailofbanban@gmail.com>",
	"keywords": [
		"obsidian",
		"plugin",
		"claude",
		"terminal",
		"tmux",
		"ai"
	],
	"license": "GPL-3.0-only",
	"repository": {
		"type": "git",
		"url": "https://github.com/zhou-ziyan/obsidian-claude-orchestrator.git"
	},
	"homepage": "https://github.com/zhou-ziyan/obsidian-claude-orchestrator",
	"bugs": {
		"url": "https://github.com/zhou-ziyan/obsidian-claude-orchestrator/issues"
	},
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^16.11.6",
		"c8": "^11.0.0",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/xterm": "^6.0.0",
		"node-pty": "^1.1.0",
		"obsidian": "latest"
	}
}
